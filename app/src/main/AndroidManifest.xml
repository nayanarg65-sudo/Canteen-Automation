<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.example.canteenautomation">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_app_logo"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_app_logo"
        android:supportsRtl="true"
        android:theme="@style/Theme.CanteenAutomation">

        <activity
            android:name=".SplashActivity"
            android:theme="@style/Theme.App.Splash"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity android:name=".LoginActivity" android:exported="false" />
        <activity android:name=".AddItemActivity" />
        <activity android:name=".AdminOrdersActivity" />
        <activity android:name=".AdminActivity" />
        <activity android:name=".SignupActivity" />
        <activity android:name=".HomePageActivity" />
        <activity android:name=".MenuActivity" />
        <activity android:name=".CartActivity" />
        <activity android:name=".InventoryManagerActivity" />

    </application>

</manifest>